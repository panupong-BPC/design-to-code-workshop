{
  "swagger": "2.0",
  "info": {
    "title": "OneKS Job Info BFF API",
    "description": "BFF endpoints for the job-info-details feature — oneks-auth-bff-service",
    "version": "1.0.0"
  },
  "host": "localhost:8087",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "tags": [
    {
      "name": "JobInfo",
      "description": "Job info details, CFA info, loan applicants, loan details, collateral"
    }
  ],
  "paths": {
    "/rest/api/v1/jobs/{jobId}": {
      "get": {
        "summary": "Get full job info details",
        "description": "Fetch full job info including general info, CFA info, loan applicants (paginated), loan details, and collateral. userId is extracted from JWT claims.",
        "operationId": "getJobInfo",
        "tags": [
          "JobInfo"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "^[A-Z]{3}[0-9]{9}$",
            "description": "Job identifier. Format: 3 uppercase letters + 9 digits",
            "x-example": "ABC000000001"
          },
          {
            "name": "applicantsPage",
            "in": "query",
            "required": false,
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "Page number for loanApplicants sub-list"
          },
          {
            "name": "applicantsPageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 10,
            "description": "Page size for loanApplicants sub-list"
          }
        ],
        "responses": {
          "200": {
            "description": "Job info details retrieved successfully",
            "schema": {
              "allOf": [
                {
                  "$ref": "#/definitions/APIResponse"
                },
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/definitions/JobInfoGetResponse"
                    }
                  }
                }
              ]
            }
          },
          "400": {
            "description": "Bad request — invalid parameters or body",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Missing or invalid JWT token",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Resource not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Unexpected server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      },
      "put": {
        "summary": "Update job info fields",
        "description": "Update overall info (signing dates, appraisal/selling price) and CFA info fields. Only provided fields are updated (partial update). userId extracted from JWT.",
        "operationId": "updateJobInfo",
        "tags": [
          "JobInfo"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "^[A-Z]{3}[0-9]{9}$",
            "description": "Job identifier. Format: 3 uppercase letters + 9 digits",
            "x-example": "ABC000000001"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/JobInfoUpdateRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job info updated successfully",
            "schema": {
              "allOf": [
                {
                  "$ref": "#/definitions/APIResponse"
                },
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/definitions/JobInfoGetResponse"
                    }
                  }
                }
              ]
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/rest/api/v1/jobs/{jobId}/contracts": {
      "get": {
        "summary": "Get grouped contract list",
        "description": "Fetch grouped contract list with document links and per-document review status. Grouped by contractType and cfaType.",
        "operationId": "getJobContracts",
        "tags": [
          "JobInfo"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "^[A-Z]{3}[0-9]{9}$",
            "description": "Job identifier. Format: 3 uppercase letters + 9 digits",
            "x-example": "ABC000000001"
          }
        ],
        "responses": {
          "200": {
            "description": "Contract list retrieved successfully",
            "schema": {
              "allOf": [
                {
                  "$ref": "#/definitions/APIResponse"
                },
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/definitions/JobContractsGetResponse"
                    }
                  }
                }
              ]
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/rest/api/v1/jobs/{jobId}/contracts/{contractId}/documents/{documentId}/review": {
      "post": {
        "summary": "Mark a contract document as reviewed",
        "description": "Toggle or set the review status on a single contract document. The handler must verify the document belongs to the contract and the job.",
        "operationId": "reviewContractDocument",
        "tags": [
          "JobInfo"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "^[A-Z]{3}[0-9]{9}$",
            "description": "Job identifier. Format: 3 uppercase letters + 9 digits",
            "x-example": "ABC000000001"
          },
          {
            "name": "contractId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Contract identifier",
            "x-example": "CTR001"
          },
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Document identifier",
            "x-example": "DOC001"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/DocumentReviewRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document review status updated",
            "schema": {
              "allOf": [
                {
                  "$ref": "#/definitions/APIResponse"
                },
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/definitions/DocumentReviewResponse"
                    }
                  }
                }
              ]
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/rest/api/v1/jobs/{jobId}/changes": {
      "get": {
        "summary": "Get change history",
        "description": "Fetch paginated change history for the View Changes panel. Returns field-level audit trail sorted by timestamp descending.",
        "operationId": "getJobChanges",
        "tags": [
          "JobInfo"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "^[A-Z]{3}[0-9]{9}$",
            "description": "Job identifier. Format: 3 uppercase letters + 9 digits",
            "x-example": "ABC000000001"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "Page number (1-based)"
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20,
            "description": "Items per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Change history retrieved successfully",
            "schema": {
              "allOf": [
                {
                  "$ref": "#/definitions/APIResponse"
                },
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/definitions/JobChangesGetResponse"
                    }
                  }
                }
              ]
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/rest/api/v1/jobs/{jobId}/submit": {
      "post": {
        "summary": "Submit workflow step",
        "description": "Submit the current workflow step (Footer Submit button). Transitions job status to the next state. Optional comment stored in audit log.",
        "operationId": "submitJob",
        "tags": [
          "JobInfo"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "^[A-Z]{3}[0-9]{9}$",
            "description": "Job identifier. Format: 3 uppercase letters + 9 digits",
            "x-example": "ABC000000001"
          },
          {
            "name": "body",
            "in": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/JobSubmitRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow step submitted successfully",
            "schema": {
              "allOf": [
                {
                  "$ref": "#/definitions/APIResponse"
                },
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/definitions/JobStatusResponse"
                    }
                  }
                }
              ]
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/rest/api/v1/jobs/{jobId}/cancel": {
      "post": {
        "summary": "Cancel workflow step",
        "description": "Cancel the current workflow step (Footer Cancel button). Transitions job status to Cancelled. reason is required.",
        "operationId": "cancelJob",
        "tags": [
          "JobInfo"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "^[A-Z]{3}[0-9]{9}$",
            "description": "Job identifier. Format: 3 uppercase letters + 9 digits",
            "x-example": "ABC000000001"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/JobCancelRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workflow step cancelled successfully",
            "schema": {
              "allOf": [
                {
                  "$ref": "#/definitions/APIResponse"
                },
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/definitions/JobStatusResponse"
                    }
                  }
                }
              ]
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "APIResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "example": "success"
        },
        "data": {
          "type": "object",
          "x-nullable": true
        },
        "message": {
          "type": "string",
          "example": ""
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "example": "error"
        },
        "code": {
          "type": "string",
          "example": "E400"
        },
        "title": {
          "type": "string",
          "example": "Bad Request"
        },
        "message": {
          "type": "string",
          "example": "Invalid request"
        }
      }
    },
    "LoanApplicant": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "APP001"
        },
        "name": {
          "type": "string",
          "example": "สมชาย ใจดี"
        },
        "role": {
          "type": "string",
          "description": "e.g. Borrower, Guarantor, Co-Borrower",
          "example": "Borrower"
        },
        "idCardNumber": {
          "type": "string",
          "example": "1234567890123"
        }
      }
    },
    "LoanApplicantPage": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LoanApplicant"
          }
        },
        "total": {
          "type": "integer",
          "example": 2
        },
        "page": {
          "type": "integer",
          "example": 1
        },
        "pageSize": {
          "type": "integer",
          "example": 10
        }
      }
    },
    "LoanDetail": {
      "type": "object",
      "properties": {
        "productCode": {
          "type": "string",
          "example": "HLN001"
        },
        "productName": {
          "type": "string",
          "example": "Home Loan"
        },
        "creditLimit": {
          "type": "number",
          "format": "double",
          "description": "Thai Baht, 2 decimal places",
          "example": 3000000
        },
        "outstandingBalance": {
          "type": "number",
          "format": "double",
          "example": 2800000
        },
        "interestRate": {
          "type": "number",
          "format": "double",
          "description": "Annual rate in percent",
          "example": 5.5
        },
        "loanType": {
          "type": "string",
          "example": "Mortgage"
        },
        "tenor": {
          "type": "integer",
          "description": "Loan tenor in months",
          "example": 300
        }
      }
    },
    "CollateralItem": {
      "type": "object",
      "properties": {
        "collateralId": {
          "type": "string",
          "example": "COL001"
        },
        "collateralType": {
          "type": "string",
          "example": "Land and House"
        },
        "titleDeedNumber": {
          "type": "string",
          "example": "1234/2566"
        },
        "landArea": {
          "type": "string",
          "example": "50 ตร.ว."
        },
        "appraisalPrice": {
          "type": "number",
          "format": "double",
          "description": "Thai Baht, 2 decimal places",
          "example": 5000000
        },
        "sellingPrice": {
          "type": "number",
          "format": "double",
          "description": "Thai Baht, 2 decimal places",
          "example": 4800000
        },
        "location": {
          "type": "string",
          "example": "Pathum Thani"
        }
      }
    },
    "ContractDocument": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "DOC001"
        },
        "name": {
          "type": "string",
          "example": "Loan Agreement Form"
        },
        "documentUrl": {
          "type": "string",
          "format": "uri",
          "example": "https://storage.example.com/docs/DOC001.pdf"
        },
        "isReviewed": {
          "type": "boolean",
          "example": false
        }
      }
    },
    "ContractGroup": {
      "type": "object",
      "properties": {
        "contractId": {
          "type": "string",
          "example": "CTR001"
        },
        "contractType": {
          "type": "string",
          "example": "Mortgage Agreement"
        },
        "cfaType": {
          "type": "string",
          "enum": [
            "CFA",
            "T/L"
          ],
          "example": "CFA"
        },
        "creditLimit": {
          "type": "number",
          "format": "double",
          "description": "Thai Baht, 2 decimal places",
          "example": 3000000
        },
        "documents": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ContractDocument"
          }
        }
      }
    },
    "ChangeHistoryItem": {
      "type": "object",
      "properties": {
        "changeId": {
          "type": "string",
          "example": "CHG001"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "example": "2026-04-16T08:00:00Z"
        },
        "changedBy": {
          "type": "string",
          "example": "user001"
        },
        "fieldName": {
          "type": "string",
          "example": "appraisalPrice"
        },
        "oldValue": {
          "type": "string",
          "description": "String-serialised previous value",
          "example": "4500000.00"
        },
        "newValue": {
          "type": "string",
          "description": "String-serialised new value",
          "example": "5000000.00"
        },
        "action": {
          "type": "string",
          "enum": [
            "CREATE",
            "UPDATE",
            "DELETE",
            "SUBMIT",
            "CANCEL"
          ],
          "example": "UPDATE"
        }
      }
    },
    "JobInfoUpdateRequest": {
      "type": "object",
      "description": "All fields optional — only provided fields are updated (partial update)",
      "properties": {
        "loanAgreementSigningDate": {
          "type": "string",
          "format": "date",
          "example": "2026-04-16"
        },
        "spouseConsentSigningDate": {
          "type": "string",
          "format": "date",
          "example": "2026-04-16"
        },
        "guaranteeSigningDate": {
          "type": "string",
          "format": "date",
          "example": "2026-04-16"
        },
        "mortgageDate": {
          "type": "string",
          "format": "date",
          "example": "2026-04-16"
        },
        "appraisalPrice": {
          "type": "number",
          "format": "double",
          "example": 5000000
        },
        "sellingPrice": {
          "type": "number",
          "format": "double",
          "example": 4800000
        },
        "cfaTotalCreditLimitOriginal": {
          "type": "number",
          "format": "double",
          "example": 3000000
        },
        "cfaTotalCreditLimitCurrent": {
          "type": "number",
          "format": "double",
          "example": 3500000
        },
        "cfaIncrementAmount": {
          "type": "number",
          "format": "double",
          "example": 500000
        },
        "cfaSigningDate": {
          "type": "string",
          "format": "date",
          "example": "2026-04-16"
        },
        "cfaRound": {
          "type": "integer",
          "minimum": 1,
          "example": 3
        }
      }
    },
    "DocumentReviewRequest": {
      "type": "object",
      "required": [
        "isReviewed"
      ],
      "properties": {
        "isReviewed": {
          "type": "boolean",
          "example": true
        }
      }
    },
    "JobSubmitRequest": {
      "type": "object",
      "properties": {
        "comment": {
          "type": "string",
          "maxLength": 500,
          "example": "All documents verified. Proceeding to next step."
        }
      }
    },
    "JobCancelRequest": {
      "type": "object",
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "maxLength": 255,
          "example": "Documents incomplete"
        },
        "comment": {
          "type": "string",
          "maxLength": 500,
          "example": "Missing signed documents from applicant"
        }
      }
    },
    "JobInfoGetResponse": {
      "type": "object",
      "properties": {
        "jobId": {
          "type": "string",
          "pattern": "^[A-Z]{3}[0-9]{9}$",
          "example": "ABC000000001"
        },
        "jobStatus": {
          "type": "string",
          "enum": [
            "Pending Start",
            "In Progress",
            "Completed",
            "Cancelled"
          ],
          "example": "In Progress"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": [
            "ป.ป.ง.",
            "Urgent"
          ]
        },
        "branch": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Each entry: 'branchCode - branchName'",
          "example": [
            "0001 - Head Office",
            "0002 - Sukhumvit Branch"
          ]
        },
        "loanAgreementSigningDate": {
          "type": "string",
          "format": "date",
          "x-nullable": true,
          "example": "2026-04-16"
        },
        "spouseConsentSigningDate": {
          "type": "string",
          "format": "date",
          "x-nullable": true,
          "example": "2026-04-16"
        },
        "guaranteeSigningDate": {
          "type": "string",
          "format": "date",
          "x-nullable": true,
          "example": "2026-04-16"
        },
        "mortgageDate": {
          "type": "string",
          "format": "date",
          "x-nullable": true,
          "example": "2026-04-16"
        },
        "appraisalPrice": {
          "type": "number",
          "format": "double",
          "x-nullable": true,
